# Base URL of the backend API. Must include the trailing /api segment.
# Only used for `npm run dev` / `npm run build` directly (no Docker). The
# Docker image ignores this and reads API_BASE_URL at container start instead
# (see frontend/docker-entrypoint.sh) — set that one for Docker/Render/etc.
VITE_API_BASE_URL=http://localhost:4000/api
