# =============================================================================
# Root environment file — used by docker-compose.yml to provision Postgres
# and to wire the backend/frontend containers together.
# Copy to ".env" and fill in real values before running `docker compose up`.
# =============================================================================

# --- Postgres (container) ---
POSTGRES_USER=forge
POSTGRES_PASSWORD=change_this_password
POSTGRES_DB=forge_fitness
POSTGRES_PORT=5432

# --- Backend (container) ---
BACKEND_PORT=4000
JWT_SECRET=replace_with_a_long_random_string_min_32_chars
JWT_EXPIRES_IN=7d
COOKIE_SECURE=false
COOKIE_SAMESITE=strict
CORS_ORIGIN=http://localhost:5173
LOG_LEVEL=info
AI_PROVIDER=none
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
AI_MODEL=claude-sonnet-4-6
APP_URL=http://localhost:8080
EMAIL_PROVIDER=none
EMAIL_FROM=FORGE Fitness <onboarding@forge.fitness>
RESEND_API_KEY=
SMTP_HOST=
SMTP_USER=
SMTP_PASSWORD=

# --- Frontend (container) ---
FRONTEND_PORT=8080
# Both read at container START (not baked into the build). Leave API_BASE_URL
# as "/api" — the browser calls the frontend's own /api path, and nginx
# proxies that to BACKEND_ORIGIN server-side, keeping everything same-origin
# even if frontend/backend end up deployed on two different domains.
API_BASE_URL=/api
BACKEND_ORIGIN=http://backend:4000
