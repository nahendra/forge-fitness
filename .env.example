# =============================================================================
# Root environment file — used by docker-compose.yml to provision Postgres
# and to wire the backend/frontend containers together.
# Copy to ".env" and fill in real values before running `docker compose up`.
# =============================================================================

# --- Postgres (container) ---
POSTGRES_USER=forge
POSTGRES_PASSWORD=change_this_password
POSTGRES_DB=forge_fitness
POSTGRES_PORT=5432

# --- Backend (container) ---
BACKEND_PORT=4000
JWT_SECRET=replace_with_a_long_random_string_min_32_chars
JWT_EXPIRES_IN=7d
COOKIE_SECURE=false
COOKIE_SAMESITE=strict
CORS_ORIGIN=http://localhost:5173
LOG_LEVEL=info
AI_PROVIDER=none
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
AI_MODEL=claude-sonnet-4-6

# --- Frontend (container) ---
FRONTEND_PORT=8080
# Read at container START (not baked into the build) — "/api" works because
# nginx (inside the frontend container) reverse-proxies /api/* to the backend
# container. Only change this if frontend/backend are split across domains.
API_BASE_URL=/api
