generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum BodyType {
  ECTOMORPH
  MESOMORPH
  ENDOMORPH
}

enum Goal {
  CUT
  BULK
  SHRED
}

model User {
  id                String   @id @default(uuid())
  email             String   @unique
  passwordHash      String
  name              String
  bodyType          BodyType @default(MESOMORPH)
  goal              Goal     @default(CUT)
  publicLeaderboard Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  workoutSessions     WorkoutSession[]
  weightLogs          WeightLog[]
  passwordResetTokens PasswordResetToken[]
  customExercises     CustomExercise[]

  @@map("users")
}

model CustomExercise {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  // Mirrors the muscle-group buckets used by the workout logger (Chest,
  // Back, ...) — not an enum since the frontend's list can grow without a
  // migration.
  bodyPart String
  name     String

  @@unique([userId, bodyPart, name])
  @@map("custom_exercises")
}

model PasswordResetToken {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  // SHA-256 hash of the token — the raw token only ever exists in the emailed
  // link, never in the database, so a DB leak alone can't be used to reset
  // anyone's password.
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("password_reset_tokens")
}

model WorkoutSession {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date      DateTime
  bodyPart  String
  notes     String?
  createdAt DateTime @default(now())

  exercises Exercise[]

  @@index([userId, date])
  @@map("workout_sessions")
}

model Exercise {
  id        String         @id @default(uuid())
  sessionId String
  session   WorkoutSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  name      String
  order     Int            @default(0)

  sets ExerciseSet[]

  @@index([sessionId])
  @@map("exercises")
}

model ExerciseSet {
  id         String   @id @default(uuid())
  exerciseId String
  exercise   Exercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  setNumber  Int
  reps       Int
  weightKg   Float

  @@index([exerciseId])
  @@map("exercise_sets")
}

model WeightLog {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date      DateTime
  weightKg  Float
  createdAt DateTime @default(now())

  @@index([userId, date])
  @@map("weight_logs")
}

model MotivationQuote {
  id     String @id @default(uuid())
  icon   String
  quote  String
  author String

  @@map("motivation_quotes")
}

model MotivationTip {
  id   String @id @default(uuid())
  text String

  @@map("motivation_tips")
}

model FitnessTruth {
  id          String @id @default(uuid())
  title       String
  description String

  @@map("fitness_truths")
}

model TransformationStory {
  id           String   @id @default(uuid())
  badge        String
  emoji        String
  category     String
  title        String
  description  String
  shares       Int      @default(0)
  gradientFrom String
  gradientTo   String
  createdAt    DateTime @default(now())

  @@map("transformation_stories")
}
