# Copy to ".env" for local (non-docker) development.

NODE_ENV=development
PORT=4000

# Postgres connection string. For docker-compose use host "db"; for local dev use "localhost".
DATABASE_URL=postgresql://forge:change_this_password@localhost:5432/forge_fitness?schema=public

# Auth
JWT_SECRET=replace_with_a_long_random_string_min_32_chars
JWT_EXPIRES_IN=7d
COOKIE_SECURE=false
# Use "none" (+ COOKIE_SECURE=true, requires HTTPS) only if frontend and backend
# are deployed on different domains (e.g. Vercel + Railway). Default "strict" is
# correct when they share a site, e.g. via the bundled nginx reverse proxy.
COOKIE_SAMESITE=strict

# CORS — must match the exact origin the frontend is served from.
CORS_ORIGIN=http://localhost:5173

# Logging: trace|debug|info|warn|error|fatal
LOG_LEVEL=info

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300
AUTH_RATE_LIMIT_MAX=10

# Optional AI enrichment for the plan generator. Leave AI_PROVIDER=none to run
# the app with zero external AI dependency (deterministic rule engine only).
AI_PROVIDER=none
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
AI_MODEL=claude-sonnet-4-6
AI_TIMEOUT_MS=8000

# Public URL of the frontend — used to build links inside outgoing emails.
APP_URL=http://localhost:5173

# Account-created confirmation email. Leave EMAIL_PROVIDER=none to skip
# sending (registration still works fine — this is purely additive).
EMAIL_PROVIDER=none
EMAIL_FROM=FORGE Fitness <onboarding@forge.fitness>
# Option A — Resend (https://resend.com), simplest to set up:
RESEND_API_KEY=
# Option B — any SMTP server (Gmail, AWS SES, Mailtrap for testing, etc.):
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
